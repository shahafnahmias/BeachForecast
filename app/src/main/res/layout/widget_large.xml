<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_large_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#101F22">

    <!-- Header: city + cloud/temp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_large_city"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_loading"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_large_cloud_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁"
            android:textSize="24sp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/widget_cd_cloud_icon" />

        <TextView
            android:id="@+id/widget_large_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Condition badge text -->
    <TextView
        android:id="@+id/widget_large_condition_badge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <!-- Summary card -->
    <LinearLayout
        android:id="@+id/widget_large_summary_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card_dark"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/widget_large_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_loading_conditions"
            android:textSize="12sp"
            android:textColor="#90C1CB"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- 2x2 vitals grid -->
    <!-- Row 1: Wind + Swell -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="8dp">

        <!-- Wind Card -->
        <LinearLayout
            android:id="@+id/widget_large_wind_card"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card_glass_dark"
            android:padding="10dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/widget_large_wind_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_wind"
                android:textSize="10sp"
                android:textColor="#5A7A82"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_large_wind_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Swell Card -->
        <LinearLayout
            android:id="@+id/widget_large_swell_card"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card_glass_dark"
            android:padding="10dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/widget_large_swell_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_swell"
                android:textSize="10sp"
                android:textColor="#5A7A82"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_large_swell_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Sea Temp + UV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="8dp">

        <!-- Sea Temp Card -->
        <LinearLayout
            android:id="@+id/widget_large_sea_temp_card"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card_glass_dark"
            android:padding="10dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/widget_large_sea_temp_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_sea_temp"
                android:textSize="10sp"
                android:textColor="#5A7A82"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_large_sea_temp_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- UV Card -->
        <LinearLayout
            android:id="@+id/widget_large_uv_card"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card_glass_dark"
            android:padding="10dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/widget_large_uv_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_uv_index_label"
                android:textSize="10sp"
                android:textColor="#5A7A82"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_large_uv_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Activity row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_large_activity_surf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="11sp"
            android:textColor="#5A7A82"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/widget_large_activity_swim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="11sp"
            android:textColor="#5A7A82"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/widget_large_activity_kite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="11sp"
            android:textColor="#5A7A82"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/widget_large_activity_sup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="11sp"
            android:textColor="#5A7A82" />
    </LinearLayout>

</LinearLayout>
